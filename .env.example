# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# --- Supabase (required for the contact form) ---
# Supabase dashboard → your project → Settings → API
# "Project URL":
NEXT_PUBLIC_SUPABASE_URL=
# "service_role" secret key (server-only — never expose in the browser):
SUPABASE_SERVICE_ROLE_KEY=

# --- Email notification (optional — form still saves without these) ---
# resend.com → API Keys
RESEND_API_KEY=
# Where new-inquiry notifications should be sent:
CONTACT_NOTIFY_EMAIL=
# Sender address; must be on a domain verified in Resend.
# Defaults to Resend's onboarding sender if unset.
CONTACT_FROM_EMAIL=SongGlow <notifications@songglow.com>
